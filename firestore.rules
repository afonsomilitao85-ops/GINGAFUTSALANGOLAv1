rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email.lower() == "afonsomilitao85@gmail.com"
      );
    }

    // --- Validation Models ---

    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'nome']) &&
             data.uid == userId &&
             data.email is string && data.email.size() <= 256 &&
             data.nome is string && data.nome.size() <= 100 &&
             (!('bairro' in data) || (data.bairro is string && data.bairro.size() <= 100)) &&
             (!('jogos' in data) || (data.jogos is number)) &&
             (!('golos' in data) || (data.golos is number)) &&
             (!('mvps' in data) || (data.mvps is number)) &&
             (!('ranking' in data) || (data.ranking is string && data.ranking.size() <= 50)) &&
             (!('isPro' in data) || (data.isPro is bool)) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 1024)) &&
             (!('provider' in data) || (data.provider is string)) &&
             (!('role' in data) || (data.role in ['user', 'admin']));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'nome', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.nome is string && data.nome.size() <= 100 &&
             (!('likes' in data) || (data.likes is number)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 1024));
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'postId']) &&
             data.userId == request.auth.uid &&
             data.postId is string && isValidId(data.postId);
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['equipaA', 'equipaB', 'status']) &&
             data.equipaA is string && data.equipaA.size() <= 100 &&
             data.equipaB is string && data.equipaB.size() <= 100 &&
             data.status in ['agendado', 'ao_vivo', 'finalizado', 'AGENDADO', 'AO VIVO', 'FINALIZADO'] &&
             (!('golosA' in data) || (data.golosA is number)) &&
             (!('golosB' in data) || (data.golosB is number)) &&
             (!('tempo' in data) || (data.tempo is string && data.tempo.size() <= 20)) &&
             (!('jornada' in data) || (data.jornada is number)) &&
             (!('grupo' in data) || (data.grupo is string || data.grupo == null)) &&
             (!('ligaId' in data) || (data.ligaId is string));
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      // Allow any signed-in user to read user profiles (needed for rankings/scout)
      // Privacy: The app should avoid storing sensitive data here or split it if needed.
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming(), userId);
      
      allow update: if isSignedIn() && (userId == request.auth.uid || isAdmin()) && (
        // Allow updating specific profile fields
        (incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'bairro', 'avatar', 'updatedAt', 'jogos', 'golos', 'mvps', 'ranking', 'isPro', 'provider', 'createdAt', 'bio', 'localizacao']) && isValidUser(incoming(), userId))
        || isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    // Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      allow update: if isSignedIn() && isValidId(postId) && (
        (isOwner(existing().authorUid) && (
          incoming().diff(existing()).affectedKeys().hasAll(['authorUid']) && isValidPost(incoming())
        )) ||
        // Public can increment likes
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes == (existing().get('likes', 0) + 1))
      ) || isAdmin();
      allow delete: if isSignedIn() && (isOwner(existing().authorUid) || isAdmin());
    }

    // Likes
    match /likes/{id} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(id) && isValidLike(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    // Matches
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(matchId);
    }

    // Leagues, Teams, Players
    match /leagues/{id} { allow read: if true; allow write: if isAdmin(); }
    match /teams/{id} { allow read: if true; allow write: if isAdmin(); }
    match /league_players/{id} { allow read: if true; allow write: if isAdmin(); }

    // Participations
    match /participations/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isValidParticipation(incoming());
      allow delete: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/teams/$(existing().equipaId)) && get(/databases/$(database)/documents/teams/$(existing().equipaId)).data.createdBy == request.auth.uid);
    }

    function isValidParticipation(data) {
      return data.keys().hasAll(['equipaId', 'competicaoId']) &&
             data.equipaId is string && data.competicaoId is string &&
             (!('grupo' in data) || (data.grupo is string || data.grupo == null)) &&
             (!('criadoEm' in data) || (data.criadoEm is number));
    }

    // Ads (Marketplace)
    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(adId);
      allow update, delete: if isSignedIn() && (isOwner(existing().authorUid) || isAdmin());
    }

    // Admins
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // System ping
    match /system/ping {
      allow read: if true;
    }
  }
}
