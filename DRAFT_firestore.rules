rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Rede de Segurança Global
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Auxiliares ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email.lower() == "afonsomilitao85@gmail.com"
      );
    }

    // --- Modelos de Validação ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'nome']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.nome is string && data.nome.size() <= 100 &&
             (!('bairro' in data) || (data.bairro is string && data.bairro.size() <= 100)) &&
             (!('jogos' in data) || (data.jogos is number)) &&
             (!('golos' in data) || (data.golos is number)) &&
             (!('mvps' in data) || (data.mvps is number)) &&
             (!('ranking' in data) || (data.ranking is string && data.ranking.size() <= 50)) &&
             (!('isPro' in data) || (data.isPro is bool)) &&
             (!('role' in data) || (data.role in ['user', 'admin']));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'nome', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.nome is string && data.nome.size() <= 100 &&
             (!('bairro' in data) || (data.bairro is string && data.bairro.size() <= 100)) &&
             (!('likes' in data) || (data.likes is number)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 1024)) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 1024)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 1024)) &&
             (!('isPro' in data) || (data.isPro is bool));
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['equipaA', 'equipaB', 'status']) &&
             data.equipaA is string && data.equipaA.size() <= 100 &&
             data.equipaB is string && data.equipaB.size() <= 100 &&
             data.status in ['AGENDADO', 'AO VIVO', 'FINALIZADO'] &&
             (!('golosA' in data) || (data.golosA is number)) &&
             (!('golosB' in data) || (data.golosB is number)) &&
             (!('tempo' in data) || (data.tempo is string && data.tempo.size() <= 20));
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'postId']) &&
             data.userId == request.auth.uid &&
             data.postId is string && isValidId(data.postId);
    }

    // --- Coleções ---

    // Utilizadores
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Rankings e listas são públicos para membros
      allow create: if isSignedIn() && uid == request.auth.uid && isValidId(uid) && isValidUser(incoming()) && !('role' in incoming());
      allow update: if isSignedIn() && uid == request.auth.uid && isValidId(uid) && (
        // Ação: Atualizar Perfil
        (incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'bairro', 'avatar', 'updatedAt']) && isValidUser(incoming())) ||
        // Ação: Atualizar Estatísticas (Pode vir de algum processamento ou do próprio user se a app permitir)
        (incoming().diff(existing()).affectedKeys().hasOnly(['jogos', 'golos', 'mvps', 'ranking', 'isPro', 'updatedAt']) && isValidUser(incoming()))
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Publicações (Posts)
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      allow update: if isSignedIn() && isValidId(postId) && (
        (isOwner(existing().authorUid) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'bairro', 'image', 'avatar', 'videoUrl', 'isPro', 'updatedAt']) && isValidPost(incoming())
        )) ||
        // Público pode atualizar os gostos de forma incremental
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes == (existing().get('likes', 0) + 1))
      ) || isAdmin();
      allow delete: if isSignedIn() && isValidId(postId) && (isOwner(existing().authorUid) || isAdmin());
    }

    // Gostos (Likes)
    match /likes/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(id) && isValidLike(incoming());
      allow delete: if isSignedIn() && isValidId(id) && isOwner(existing().userId);
    }

    // Jogos (Matches)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(matchId);
      allow update: if isAdmin() && isValidId(matchId) && existing().status != 'FINALIZADO' && isValidMatch(incoming());
    }

    // Ligas, Equipas, Jogadores
    match /leagues/{id} { allow read: if true; allow write: if isAdmin() && isValidId(id); }
    match /teams/{id} { allow read: if true; allow write: if isAdmin() && isValidId(id); }
    match /league_players/{id} { allow read: if true; allow write: if isAdmin() && isValidId(id); }

    // Anúncios (Mercado)
    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(adId); // Simplified create for ads
      allow update: if isSignedIn() && isValidId(adId) && isOwner(existing().authorUid) || isAdmin();
      allow delete: if isSignedIn() && isValidId(adId) && (isOwner(existing().authorUid) || isAdmin());
    }

    // Coleção de Administradores
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Teste de ligação
    match /system/ping {
      allow read: if true;
    }
  }
}
